---
import "../styles/global.css";
import "../styles/wechat.css";
const { title = "AI 趋势脉冲" } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/hotspots", label: "热点" },
  { href: "/archive", label: "日报" },
  { href: "/graph", label: "图谱" },
  { href: "/institutions", label: "机构" },
  { href: "/github", label: "GitHub" },
  { href: "/watchlist", label: "Watchlist" },
  { href: "/sources", label: "数据源" },
];
function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="发现 AI 研究、开源项目、方法、Benchmark 与机构信号中的异常波动" />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="brand" href="/">
            <span class="brand-mark">AI</span>
            <span>趋势脉冲</span>
          </a>
          <div class="topbar-actions">
            <nav class="nav" aria-label="主导航">
              {navItems.map((item) => (
                <a class:list={[isActive(item.href) && "active"]} href={item.href}>{item.label}</a>
              ))}
            </nav>
            <details class="wechat-nav">
              <summary>公众号</summary>
              <div class="wechat-popover" role="dialog" aria-label="公众号二维码">
                <div class="wechat-popover-title">公众号：灵感与观点交流</div>
                <img src="/wechat-qr.svg" alt="公众号二维码" loading="lazy" />
                <div class="wechat-popover-hint">微信扫码关注</div>
              </div>
            </details>
          </div>
        </div>
      </header>
      <main class="page">
        <slot />
      </main>
      <footer class="footer">
        AI Trend Seismograph · 趋势判断来自公开论文、代码与配置词典信号，不构成投资、科研选题或技术路线建议。
      </footer>
    </div>
  </body>
</html>
