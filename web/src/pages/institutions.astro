---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstitutionClusterCard from "../components/InstitutionClusterCard.astro";
import { institutionsConfig, latestBundle } from "../lib/data";

const institutions = institutionsConfig();
const { report } = latestBundle();
const clusters = report?.institution_clusters || [];
---
<BaseLayout title="机构 - AI 趋势脉冲">
  <section class="page-title">
    <h1>机构发布频率</h1>
    <p class="subtitle">展示高权重机构词典、最近 7 天活跃机构和机构-topic 集中度异常。</p>
  </section>
  <section class="grid cols-3">
    {clusters.slice(0, 12).map((cluster: any) => <InstitutionClusterCard cluster={cluster} />)}
    {!clusters.length && <div class="empty">暂无机构集中异常。</div>}
  </section>

  <h2>机构词典</h2>
  <table class="table">
    <thead><tr><th>机构</th><th>别名</th><th>权重</th><th>关注方向</th></tr></thead>
    <tbody>{institutions.map((item: any) => <tr><td>{item.name}</td><td>{(item.aliases || []).join("、")}</td><td>{item.weight}</td><td>{(item.focus_topics || []).join("、")}</td></tr>)}</tbody>
  </table>
</BaseLayout>
