---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrendCard from "../components/TrendCard.astro";
import GithubSurgeCard from "../components/GithubSurgeCard.astro";
import DatasetBurstCard from "../components/DatasetBurstCard.astro";
import MethodBurstCard from "../components/MethodBurstCard.astro";
import InstitutionClusterCard from "../components/InstitutionClusterCard.astro";
import SourceStatus from "../components/SourceStatus.astro";
import WatchlistHitCard from "../components/WatchlistHitCard.astro";
import { formatBeijingHour, latestBundle } from "../lib/data";

const { hourly, report } = latestBundle();
const anomalies = report?.top_anomalies || hourly?.top_hotspots || [];
const maxMagnitude = report?.max_magnitude || hourly?.max_magnitude || 0;
const latestHourLabel = formatBeijingHour(hourly?.snapshot_hour);
---
<BaseLayout title="AI 趋势脉冲">
  <section class="page-title">
    <h1>AI 趋势脉冲</h1>
    <p class="subtitle">发现 AI 研究与工程方向的异常波动，聚合论文、开源项目、方法、数据集、Benchmark 与机构信号。</p>
  </section>

  <section class="grid cols-4">
    <div class="panel metric"><div class="value">{latestHourLabel}</div><div class="label">最近小时刷新</div></div>
    <div class="panel metric"><div class="value">{hourly?.total_items_scanned ?? 0}</div><div class="label">最近 1 小时新增信号</div></div>
    <div class="panel metric"><div class="value">M{Number(maxMagnitude || 0).toFixed(1)}</div><div class="label">当前最高震级</div></div>
    <div class="panel metric"><div class="value">{hourly?.push_recommended ? "是" : "否"}</div><div class="label">是否存在建议推送热点</div></div>
  </section>

  <h2>Top 5 趋势异常</h2>
  <section class="grid cols-2">
    {anomalies.length ? anomalies.slice(0, 5).map((trend: any) => <TrendCard trend={trend} detailed={true} />) : <div class="empty">暂无趋势异常。请先运行小时或日报流水线。</div>}
  </section>

  <h2>过去 1 小时热点</h2>
  <section class="grid cols-2">
    {(hourly?.top_hotspots || []).slice(0, 4).map((trend: any) => <TrendCard trend={trend} detailed={true} />)}
    {!hourly?.top_hotspots?.length && <div class="empty">暂无小时热点。</div>}
  </section>

  <h2>GitHub 暴涨项目</h2>
  <section class="grid cols-3">
    {(report?.github_surges || hourly?.github_surges || []).slice(0, 6).map((repo: any) => <GithubSurgeCard repo={repo} />)}
    {!(report?.github_surges || hourly?.github_surges || []).length && <div class="empty">暂无 GitHub 增长曲线；首次运行需要先积累 repo snapshot。</div>}
  </section>

  <h2>数据集 / Benchmark 异常</h2>
  <section class="grid cols-3">
    {(report?.dataset_bursts || hourly?.dataset_bursts || []).slice(0, 6).map((item: any) => <DatasetBurstCard item={item} />)}
    {!(report?.dataset_bursts || hourly?.dataset_bursts || []).length && <div class="empty">暂无数据集或 Benchmark 异常。</div>}
  </section>

  <h2>方法采用异常</h2>
  <section class="grid cols-3">
    {(report?.method_bursts || hourly?.method_bursts || []).slice(0, 6).map((item: any) => <MethodBurstCard item={item} />)}
    {!(report?.method_bursts || hourly?.method_bursts || []).length && <div class="empty">暂无方法扩散异常。</div>}
  </section>

  <h2>机构连续发布信号</h2>
  <section class="grid cols-3">
    {(report?.institution_clusters || []).slice(0, 6).map((cluster: any) => <InstitutionClusterCard cluster={cluster} />)}
    {!report?.institution_clusters?.length && <div class="empty">暂无机构集中信号。</div>}
  </section>

  <h2>Watchlist 命中</h2>
  <section class="grid cols-2">
    {(report?.watchlist?.hits || hourly?.watchlist_hits || []).slice(0, 6).map((hit: any) => <WatchlistHitCard hit={hit} />)}
    {!(report?.watchlist?.hits || hourly?.watchlist_hits || []).length && <div class="empty">当前没有 Watchlist 命中。</div>}
  </section>

  <h2>今日观察建议</h2>
  <section class="panel">
    {anomalies.length ? (
      <ul>
        {anomalies.slice(0, 6).map((trend: any) => <li>{trend.topic}：{(trend.suggested_watch_keywords || []).slice(0, 6).join("、") || "继续观察后续 3-7 天证据"}</li>)}
      </ul>
    ) : <p class="muted">暂无观察建议。</p>}
  </section>

  <h2>数据源状态</h2>
  <SourceStatus sources={report?.raw_sources_summary?.source_status || hourly?.source_status || []} />
</BaseLayout>
