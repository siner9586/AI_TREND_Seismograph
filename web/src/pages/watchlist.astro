---
import BaseLayout from "../layouts/BaseLayout.astro";
import WatchlistHitCard from "../components/WatchlistHitCard.astro";
import Sparkline from "../components/Sparkline.astro";
import { latestBundle, watchlistConfig } from "../lib/data";

const watchlists = watchlistConfig();
const { report, hourly } = latestBundle();
const hits = report?.watchlist?.hits || hourly?.watchlist_hits || [];
---
<BaseLayout title="Watchlist - AI 趋势脉冲">
  <section class="page-title">
    <h1>Watchlist</h1>
    <p class="subtitle">关注方向、阈值、最近命中、历史震级与推送状态。</p>
  </section>
  <section class="grid cols-3">
    {watchlists.map((item: any) => (
      <article class="card stack">
        <h3>{item.name}</h3>
        <div class="muted">阈值 M{item.threshold_magnitude} · growth {item.threshold_growth_rate ?? "-"}</div>
        <div class="row">{(item.topics || []).map((topic: string) => <span class="tag">{topic}</span>)}</div>
        <Sparkline points={[]} />
      </article>
    ))}
  </section>
  <h2>最近命中</h2>
  <section class="grid cols-2">
    {hits.map((hit: any) => <WatchlistHitCard hit={hit} />)}
    {!hits.length && <div class="empty">暂无 Watchlist 命中。</div>}
  </section>
</BaseLayout>
