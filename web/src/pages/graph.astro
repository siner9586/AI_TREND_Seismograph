---
import BaseLayout from "../layouts/BaseLayout.astro";
import CooccurrenceGraphLite from "../components/CooccurrenceGraphLite.astro";
import { readJson } from "../lib/data";

const graph = readJson<any>("data/graphs/cooccurrence/latest.json", { nodes: [], edges: [] });
---
<BaseLayout title="关键词共现网络 - AI 趋势脉冲">
  <section class="page-title">
    <h1>关键词共现网络</h1>
    <p class="subtitle">基于公开论文与 GitHub 项目信号构建，呈现近期 AI 方向之间的语义关联、方法扩散与议题聚合结构。</p>
  </section>
  <CooccurrenceGraphLite graph={graph} />
  <h2>高频节点</h2>
  <table class="table">
    <thead><tr><th>关键词</th><th>类型</th><th>次数</th><th>权重</th></tr></thead>
    <tbody>{(graph.nodes || []).slice(0, 40).map((node: any) => <tr><td>{node.label}</td><td>{node.type}</td><td>{node.count}</td><td>{node.weight}</td></tr>)}</tbody>
  </table>
</BaseLayout>
