---
const { evidence = [], limit = 4 } = Astro.props;
---
{evidence?.length ? (
  <ul class="evidence-list">
    {evidence.slice(0, limit).map((item: any) => (
      <li>
        <a href={item.source_url} target="_blank" rel="noopener noreferrer">{item.title || item.source_url}</a>
        <span> · {item.source_name || item.source_type} · score {item.match_score ?? "-"}</span>
      </li>
    ))}
  </ul>
) : <p class="muted">暂无可展示证据链。</p>}
